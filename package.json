{
  "name": "watch-party-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "MVP сервиса совместного просмотра YouTube-видео с чатом на микросервисной архитектуре.",
  "workspaces": [
    "services/*",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "dev:gateway": "npm --workspace @watchparty/api-gateway run dev",
    "dev:auth": "npm --workspace @watchparty/auth-service run dev",
    "dev:room": "npm --workspace @watchparty/room-service run dev",
    "dev:chat": "npm --workspace @watchparty/chat-service run dev",
    "dev:realtime": "npm --workspace @watchparty/realtime-service run dev",
    "dev:frontend": "npm --workspace frontend run dev"
  }
}
